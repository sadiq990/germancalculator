{
  "expo": {
    "name": "Stundenrechner Pro",
    "slug": "stundenrechner-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1558C9"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "de.stundenrechnerpro.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Kein Zugriff erforderlich",
        "UIBackgroundModes": ["background-fetch", "remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1558C9"
      },
      "package": "de.stundenrechnerpro.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1558C9",
          "sounds": [],
          "mode": "production"
        }
      ],
      "expo-secure-store",
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "stundenrechner-pro-project-id"
      }
    }
  }
}
